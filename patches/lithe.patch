+
+/* Lithe's dedicated Vibes tab owns a persistent, intentionally obvious
+ * recommendation control strip. These selectors are inert in normal tabs. */
+notification-message.lithe-vibes-controls {
+  color: #f2e6c9;
+  font-family: "Courier New", monospace;
+  font-weight: 700;
+  letter-spacing: 0.04em;
+  border-block: 2px solid #80e1be;
+}
+
+notification-message.lithe-vibes-controls .notification-button-container {
+  gap: 8px;
+}
+
+notification-message.lithe-vibes-controls .notification-button {
+  min-width: 72px;
+  min-height: 30px;
+  padding-inline: 10px;
+  color: #181c23 !important;
+  background-color: #f2e6c9 !important;
+  border: 2px solid #181c23 !important;
+  border-radius: 2px !important;
+  box-shadow: 2px 2px 0 #80e1be;
+  font-family: "Courier New", monospace;
+  font-weight: 700;
+  letter-spacing: 0.06em;
+}
+
+notification-message.lithe-vibes-controls
+  .notification-button:is(:hover, [data-selected="true"]) {
+  color: #f2e6c9 !important;
+  background-color: #285347 !important;
+}
+
+notification-message.lithe-vibes-controls
+  .notification-button[data-lithe-vibes-action="back"]::before {
+  content: "◀ ";
+}
+
+notification-message.lithe-vibes-controls
+  .notification-button[data-lithe-vibes-action="next"]::after {
+  content: " ▶";
+}
+
+notification-message.lithe-vibes-controls
+  .notification-button:is(
+    [data-lithe-vibes-action="like"],
+    [data-lithe-vibes-action="dislike"]
+  ) {
+  padding-inline-start: 32px;
+  background-position: 9px center;
+  background-repeat: no-repeat;
+  background-size: 16px;
+}
+
+notification-message.lithe-vibes-controls
+  .notification-button[data-lithe-vibes-action="like"] {
+  background-image: url("chrome://branding/content/vibes-thumb-up.svg");
+}
+
+notification-message.lithe-vibes-controls
+  .notification-button[data-lithe-vibes-action="dislike"] {
+  background-image: url("chrome://branding/content/vibes-thumb-down.svg");
+}
